# ──────────────────────────────────────────────────────────────
# InfluxDB 3 AI Stack Demo — Environment Variables
# ──────────────────────────────────────────────────────────────
# Do not edit this file directly.
# Run bash scripts/setup.sh — it creates .env from this template
# and fills in all auto-generated values for you.

# ── InfluxDB 3 Enterprise ──────────────────────────────────────
# Required: your email to activate a free trial license on first boot
INFLUXDB3_ENTERPRISE_LICENSE_EMAIL=

# Auto-generated by scripts/setup.sh — do not set manually
INFLUXDB3_AUTH_TOKEN=

# ── InfluxDB 3 Explorer ────────────────────────────────────────
# Auto-generated by scripts/setup.sh — do not set manually
EXPLORER_SESSION_SECRET_KEY=
